# Modo local:
# true  = muestra Abrir carpeta / Abrir ubicación / Abrir archivo
# false = modo web/servidor; solo descarga archivo y ZIP
ICEBERG_MODO_LOCAL=true

# Valores sugeridos:
# local | codespaces | docker | streamlit_cloud
ICEBERG_ENTORNO=local

# Opcional si decides manejar credenciales por entorno.
# Por ahora la app pide credenciales en la interfaz.
# ICEBERG_USER=
# ICEBERG_PASS=
