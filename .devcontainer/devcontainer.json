{
  "name": "ICEBERG Streamlit",
  "image": "mcr.microsoft.com/playwright/python:v1.55.0-noble",
  "postCreateCommand": "pip install --no-cache-dir -r requirements.txt && python -m playwright install chromium",
  "forwardPorts": [8501],
  "portsAttributes": {
    "8501": {
      "label": "ICEBERG Streamlit",
      "onAutoForward": "openBrowser"
    }
  },
  "containerEnv": {
    "ICEBERG_MODO_LOCAL": "false",
    "ICEBERG_ENTORNO": "codespaces",
    "PYTHONIOENCODING": "utf-8",
    "PYTHONUTF8": "1"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
